<%- include('partials/navbar') %>
<link rel="stylesheet" href="/styles.css">

<style>
    body {
        background: #0f172a;
        color: white;
    }

    .container {
        padding: 25px;
    }

    h1, h2 {
        color: #38bdf8;
    }

    /* =========================
       📊 RESUMEN CARDS
    ========================= */
    .grid-summary {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        margin-top: 20px;
    }

    .card {
        background: #111827;
        padding: 18px;
        border-radius: 14px;
        border: 1px solid rgba(56,189,248,0.12);
        box-shadow: 0 0 20px rgba(56,189,248,0.06);
        text-align: center;
    }

    /* =========================
       🏠 GRID HABITACIONES
    ========================= */
    .grid-rooms {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 12px;
        margin-top: 20px;
    }

    .room-card {
        border-radius: 14px;
        padding: 14px;
        text-align: center;
        position: relative;
        transition: 0.2s;

        display: flex;
        flex-direction: column;
        gap: 8px;

        min-height: 170px;
        overflow: hidden;
    }

    .room-card:hover {
        transform: translateY(-3px);
    }

    /* =========================
       🟢 OCUPADA (BUENA)
    ========================= */
    .room-card.ocupada {
        background: #22c55e;
        color: #0f172a;
        border: 2px solid #16a34a;
    }

    /* =========================
       🔴 LIBRE (ALERTA)
    ========================= */
    .room-card.libre {
        background: #ef4444;
        color: white;
        border: 2px solid #b91c1c;
    }

    /* =========================
       🏷 BADGE
    ========================= */
    .badge-status {
        position: absolute;
        top: 8px;
        right: 8px;
        padding: 4px 10px;
        font-size: 11px;
        border-radius: 999px;
        color: white;
        text-transform: capitalize;
        background: rgba(0,0,0,0.25);
    }

    /* =========================
       👤 INFO
    ========================= */
    .tenant, .available {
        font-size: 13px;
        font-weight: 500;
    }

    /* =========================
       💰 FORM PRECIO FIX
    ========================= */
    form {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        margin-top: auto;
        width: 100%;
    }

    input {
        width: 100%;
        max-width: 120px;
        padding: 6px;
        border-radius: 8px;
        border: none;
        text-align: center;
        outline: none;
        font-size: 12px;
    }

    button {
        width: 100%;
        max-width: 120px;
        padding: 6px;
        font-size: 12px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
    }

    .room-card.ocupada button {
        background: #0f172a;
        color: white;
    }

    .room-card.libre button {
        background: #111827;
        color: white;
    }
</style>

<div class="container">

<h1>🏢 Dashboard de Habitaciones</h1>

<!-- 📊 RESUMEN -->
<div class="grid-summary">

    <div class="card">
        <h3>🏠 Total Habitaciones</h3>
        <h2><%= total %></h2>
    </div>

    <div class="card">
        <h3>🟢 Libres</h3>
        <h2><%= libres %></h2>
    </div>

    <div class="card">
        <h3>🔴 Ocupadas</h3>
        <h2><%= ocupadas %></h2>
    </div>

</div>

<!-- 📌 LISTA -->
<h2 style="margin-top:30px;">📋 Estado de Habitaciones</h2>

<div class="grid-rooms">

    <% data.forEach(h => { %>

        <div class="room-card <%= h.estado %>">

            <div class="badge-status">
                <%= h.estado %>
            </div>

            <h2><%= h.numero %></h2>

            <% if (h.inquilino) { %>

                <div class="tenant">
                    👤 <%= h.inquilino %>
                </div>

                <form action="/habitaciones/precio" method="POST">

                    <input type="hidden" name="habitacion" value="<%= h.numero %>">

                    <input 
                        type="number" 
                        name="precio" 
                        value="<%= h.precio || 0 %>" 
                        placeholder="Precio"
                    >

                    <button type="submit">
                        💾 Guardar
                    </button>

                </form>

            <% } else { %>

                <div class="available">
                    Disponible
                </div>

            <% } %>

        </div>

    <% }) %>

</div>

</div>