<%- include('partials/navbar') %>
<link rel="stylesheet" href="/styles.css">

<style>
    body {
        background: #0b1220;
        color: white;
    }

    .container {
        padding: 25px;
    }

    h1 {
        color: #38bdf8;
    }

    /* =========================
       RESUMEN
    ========================= */
    .grid-summary {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        margin-top: 20px;
    }

    .card {
        background: rgba(17, 24, 39, 0.6);
        backdrop-filter: blur(10px);
        border-radius: 14px;
        padding: 18px;
        border: 1px solid rgba(56,189,248,0.15);
        text-align: center;
    }

    /* 🟢 OCUPADAS */
    .card.ocupadas {
        border: 1px solid #22c55e;
        box-shadow: 0 0 12px rgba(34,197,94,0.25);
    }

    /* 🔴 LIBRES */
    .card.libres {
        border: 1px solid #ef4444;
        box-shadow: 0 0 12px rgba(239,68,68,0.25);
    }

    /* =========================
       GRID HABITACIONES
    ========================= */
    .grid-rooms {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 14px;
        margin-top: 20px;
    }

    /* =========================
       CARD HABITACIÓN
    ========================= */
    .room-card {
        position: relative;
        border-radius: 16px;
        padding: 14px;

        background: rgba(255,255,255,0.03);
        backdrop-filter: blur(12px);

        display: flex;
        flex-direction: column;
        align-items: center;

        min-height: 160px;

        overflow: hidden;
        transition: 0.2s;
    }

    .room-card.ocupada {
        border: 1px solid #22c55e;
        box-shadow: inset 0 0 0 1px rgba(34,197,94,0.4),
                    0 0 12px rgba(34,197,94,0.25);
    }

    .room-card.libre {
        border: 1px solid #ef4444;
        box-shadow: inset 0 0 0 1px rgba(239,68,68,0.4),
                    0 0 12px rgba(239,68,68,0.25);
    }

    /* =========================
       BADGE
    ========================= */
    .badge-status {
        position: absolute;
        top: 8px;
        right: 8px;

        font-size: 10px;
        padding: 4px 10px;
        border-radius: 999px;

        font-weight: bold;
        text-transform: capitalize;
    }

    .room-card.ocupada .badge-status {
        background: #22c55e;
        color: #0b0f14;
    }

    .room-card.libre .badge-status {
        background: #ef4444;
        color: white;
    }

    /* =========================
       NUMERO HABITACION
    ========================= */
    .room-number {
        font-size: 20px;
        font-weight: bold;
        margin-top: 10px;
    }

    /* =========================
       INQUILINO (REDUCIDO)
    ========================= */
    .tenant {
        font-size: 11px;
        color: #cbd5e1;
        margin: 6px 0;
        text-align: center;

        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* =========================
       FORM MINI PERO VISIBLE (BORDES INTERNOS)
    ========================= */
    form {
        width: 85%;
        margin-top: auto;

        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;

        padding: 8px;
        border-radius: 12px;

        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(0,0,0,0.15);
    }

    input {
        width: 80%;
        padding: 5px;

        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.1);

        background: rgba(0,0,0,0.3);
        color: white;

        text-align: center;
        font-size: 12px;
    }

    button {
        width: 80%;
        padding: 5px;

        font-size: 11px;
        border-radius: 8px;

        border: none;
        cursor: pointer;

        background: rgba(56,189,248,0.25);
        color: white;
    }

    button:hover {
        background: rgba(56,189,248,0.4);
    }

    /* =========================
       DISPONIBLE
    ========================= */
    .available {
        font-size: 12px;
        color: #94a3b8;
        margin-top: 10px;
    }
</style>

<div class="container">

<h1>🏢 Dashboard de Habitaciones</h1>

<!-- RESUMEN -->
<div class="grid-summary">

    <div class="card ocupadas">
        <h3>🟢 Ocupadas</h3>
        <h2><%= ocupadas %></h2>
    </div>

    <div class="card libres">
        <h3>🔴 Libres</h3>
        <h2><%= libres %></h2>
    </div>

    <div class="card">
        <h3>🏠 Total</h3>
        <h2><%= total %></h2>
    </div>

</div>

<!-- HABITACIONES -->
<div class="grid-rooms">

    <% data.forEach(h => { %>

        <div class="room-card <%= h.estado %>">

            <div class="badge-status"><%= h.estado %></div>

            <div class="room-number"><%= h.numero %></div>

            <% if (h.inquilino) { %>

                <div class="tenant">👤 <%= h.inquilino %></div>

                <form action="/habitaciones/precio" method="POST">

                    <input type="hidden" name="habitacion" value="<%= h.numero %>">

                    <input type="number" name="precio" value="<%= h.precio || 0 %>">

                    <button type="submit">Guardar</button>

                </form>

            <% } else { %>

                <div class="available">Sin inquilino</div>

            <% } %>

        </div>

    <% }) %>

</div>

</div>