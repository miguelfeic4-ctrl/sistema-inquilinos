<!DOCTYPE html>

<html>
<head>
    <title>Reporte Inquilinos</title>
    <link rel="stylesheet" href="/styles.css">

<style>
    body {
        background: #0f172a;
        color: white;
    }

    .container {
        padding: 25px;
    }

    h1 {
        color: #38bdf8;
        margin-bottom: 15px;
    }

    /* =========================
       📊 TABLA MODERNA
    ========================= */
    table {
        width: 100%;
        margin-top: 25px;
        border-collapse: collapse;
        background: #111827;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 0 20px rgba(56,189,248,0.08);
        border: 1px solid rgba(56,189,248,0.1);
    }

    th {
        background: #1f2937;
        color: #38bdf8;
        padding: 12px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    td {
        padding: 12px;
        text-align: center;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        color: #e5e7eb;
        font-size: 14px;
    }

    tr:hover {
        background: rgba(56,189,248,0.05);
    }

    /* =========================
       📥 BOTÓN EXCEL
    ========================= */
    .btn {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 10px;
        cursor: pointer;
        font-weight: bold;
        transition: 0.2s;
        box-shadow: 0 0 12px rgba(34,197,94,0.2);
    }

    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 0 18px rgba(34,197,94,0.35);
    }

    /* =========================
       🏷 BADGES OPCIONAL FUTURO
    ========================= */
    .badge {
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        color: white;
        background: #38bdf8;
    }

</style>

</head>

<body>

<%- include('partials/navbar') %>

<div class="container">

<h1>📋 Reporte de Inquilinos</h1>
<form method="GET" style="display:flex;gap:10px;margin-bottom:15px;">

    <select name="mes">
        <% const meses = ["Enero","Febrero","Marzo","Abril","Mayo","Junio",
        "Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre"]; %>

        <% meses.forEach((m, i) => { %>
            <option value="<%= i+1 %>" <%= mes == i+1 ? 'selected' : '' %>>
                <%= m %>
            </option>
        <% }) %>
    </select>

    <input type="number" name="anio" value="<%= anio %>">

    <button type="submit">Filtrar</button>
</form>

<table>
    <tr>
        <th>Nombre</th>
        <th>DNI</th>
        <th>Teléfono</th>
        <th>Correo</th>
        <th>Habitación</th>
        <th>Ingreso</th>
        <th>Garantía</th>
        <th>Precio</th>
    </tr>

    <% data.forEach(i => { %>
        <tr>

            <td><%= i.nombreCompleto %></td>
            <td><%= i.dni %></td>
            <td><%= i.telefono %></td>
            <td><%= i.correo %></td>
            <td><%= i.habitacion %></td>

            <td>
                <%= i.fechaIngreso 
                    ? new Date(i.fechaIngreso).toLocaleDateString() 
                    : '-' %>
            </td>

            <td>S/ <%= i.montoGarantia %></td>
            <td>S/ <%= i.precio %></td>

        </tr>
    <% }) %>

</table>

<!-- BOTÓN EXCEL -->
<div style="margin-top:30px;text-align:center;">
   <a href="/reportes/inquilinos/excel?mes=<%= mes %>&anio=<%= anio %>">
        <button class="btn">
            📥 Generar Excel
        </button>
    </a>
</div>

</div>

</body>
</html>