<!DOCTYPE html>
<html>
<head>
    <title>Inquilinos</title>
    <link rel="stylesheet" href="/styles.css">

    <style>
        .grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 20px;
        }

        .card {
            padding: 15px;
            border-radius: 10px;
            background: #f4f4f4;
            text-align: center;
        }

        table {
            width: 100%;
            margin-top: 20px;
            border-collapse: collapse;
            background: white;
            border-radius: 10px;
            overflow: hidden;
        }

        th, td {
            padding: 10px;
            border-bottom: 1px solid #ddd;
        }

        th {
            background: #1f2937;
            color: white;
        }

        tr:hover {
            background: #f3f4f6;
        }

        .btn {
            padding: 5px 10px;
            text-decoration: none;
            background: black;
            color: white;
            border-radius: 5px;
            font-size: 12px;
        }

        .acciones a {
            margin-right: 8px;
        }

        /* estados visuales */
        .activo { border-left: 5px solid green; }
        .moroso { border-left: 5px solid red; }
        .suspendido { border-left: 5px solid orange; }
        .retirado { border-left: 5px solid gray; }
        .en\ evaluacion { border-left: 5px solid blue; }

    </style>
</head>

<body>

<%- include('partials/navbar') %>

<div class="container">

    <h1>👥 Gestión de Inquilinos</h1>

    <!-- RESUMEN -->
    <div class="grid">

        <div class="card">
            <h2>Total Inquilinos</h2>
            <h1><%= inquilinos.length %></h1>
        </div>

        <div class="card">
            <h2>Activos</h2>
            <h1><%= inquilinos.filter(i => i.estado === 'activo').length %></h1>
        </div>

        <div class="card">
            <h2>Morosos</h2>
            <h1><%= inquilinos.filter(i => i.estado === 'moroso').length %></h1>
        </div>

    </div>

    <!-- TABLA -->
    <table>

        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>DNI</th>
            <th>Teléfono</th>
            <th>Correo</th>
            <th>Estado</th>
            <th>Ingreso</th>
            <th>Habitación</th>
            <th>Acciones</th>
        </tr>

        <% inquilinos.forEach(i => { %>
            <tr class="<%= i.estado %>">

                <td><%= i.codigo || '-' %></td>
                <td><%= i.nombreCompleto %></td>
                <td><%= i.dni %></td>
                <td><%= i.telefono || '-' %></td>
                <td><%= i.correo || '-' %></td>

                <td><%= i.estado %></td>

                <td>
                    <%= i.fechaIngreso ? i.fechaIngreso.toString().slice(0,10) : '-' %>
                </td>

                <!-- 🔥 HABITACIÓN NUEVA -->
                <td><%= i.habitacion || '-' %></td>

                <td class="acciones">
                    <a class="btn" href="/editar/<%= i.id %>">Editar</a>
                    <a class="btn" href="/eliminar/<%= i.id %>">Eliminar</a>
                </td>

            </tr>
        <% }) %>

    </table>

</div>

</body>
</html>