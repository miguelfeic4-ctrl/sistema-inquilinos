<!DOCTYPE html>
<html>
<head>
    <title>Inquilinos</title>
    <link rel="stylesheet" href="/styles.css">

    <style>
        /* =========================
           📊 GRID RESUMEN PRO
        ========================= */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 15px;
            margin-bottom: 25px;
        }

        .card {
            padding: 18px;
            border-radius: 14px;
            background: #111827;
            text-align: center;
            border: 1px solid rgba(56,189,248,0.15);
            box-shadow: 0 0 20px rgba(56,189,248,0.08);
            transition: 0.2s;
        }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 25px rgba(56,189,248,0.15);
        }

        .card h1 {
            color: #38bdf8;
            margin: 5px 0 0 0;
        }

        .card h2 {
            font-size: 14px;
            color: #cbd5e1;
        }

        /* =========================
           📊 TABLA PRO
        ========================= */
        table {
            width: 100%;
            margin-top: 20px;
            border-collapse: collapse;
            background: #111827;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 0 20px rgba(56,189,248,0.08);
            border: 1px solid rgba(56,189,248,0.15);
        }

        th {
            background: #0f172a;
            color: #38bdf8;
            padding: 12px;
            text-align: left;
            font-size: 13px;
        }

        td {
            padding: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            color: #e5e7eb;
            font-size: 13px;
        }

        tr:hover {
            background: rgba(56,189,248,0.08);
        }

        /* =========================
           🔘 BOTONES PRO
        ========================= */
        .btn {
            padding: 6px 10px;
            text-decoration: none;
            background: linear-gradient(135deg, #38bdf8, #2563eb);
            color: white;
            border-radius: 8px;
            font-size: 12px;
            transition: 0.2s;
            display: inline-block;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 12px rgba(56,189,248,0.3);
        }

        .acciones a {
            margin-right: 6px;
        }

        /* =========================
           🟢 ESTADOS NEON SOFT
        ========================= */
        .activo { border-left: 4px solid #2ecc71; }
        .moroso { border-left: 4px solid #ef4444; }
        .suspendido { border-left: 4px solid #f59e0b; }
        .retirado { border-left: 4px solid #6b7280; }
        .en\ evaluacion { border-left: 4px solid #38bdf8; }
    </style>
</head>

<body>

<%- include('partials/navbar') %>

<div class="container">

    <h1>👥 Gestión de Inquilinos</h1>

    <!-- RESUMEN -->
    <div class="grid">

        <div class="card">
            <h2>Total Inquilinos</h2>
            <h1><%= inquilinos.length %></h1>
        </div>

        <div class="card">
            <h2>Activos</h2>
            <h1><%= inquilinos.filter(i => i.estado === 'activo').length %></h1>
        </div>

        <div class="card">
            <h2>Morosos</h2>
            <h1><%= inquilinos.filter(i => i.estado === 'moroso').length %></h1>
        </div>

    </div>

    <!-- TABLA -->
    <table>

        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>DNI</th>
            <th>Teléfono</th>
            <th>Correo</th>
            <th>Estado</th>
            <th>Ingreso</th>
            <th>Habitación</th>
            <th>Acciones</th>
        </tr>

        <% inquilinos.forEach(i => { %>
            <tr class="<%= i.estado %>">

                <td><%= i.codigo || '-' %></td>
                <td><%= i.nombreCompleto %></td>
                <td><%= i.dni %></td>
                <td><%= i.telefono || '-' %></td>
                <td><%= i.correo || '-' %></td>

                <td>
                    <span class="badge <%= i.estado %>">
                        <%= i.estado %>
                    </span>
                </td>

                <td>
                    <%= i.fechaIngreso ? i.fechaIngreso.toString().slice(0,10) : '-' %>
                </td>

                <td><%= i.habitacion || '-' %></td>

                <td class="acciones">
                    <a class="btn" href="/editar/<%= i.id %>">Editar</a>
                    <a class="btn" href="/eliminar/<%= i.id %>">Eliminar</a>
                </td>

            </tr>
        <% }) %>

    </table>

</div>

</body>
</html>