<!DOCTYPE html>

<html>
<head>
    <title>Reporte Pagos</title>
    <link rel="stylesheet" href="/styles.css">

<style>
    body {
        background: #0f172a;
        color: white;
    }

    .container {
        padding: 25px;
    }

    h1 {
        color: #38bdf8;
        margin-bottom: 15px;
    }

    /* =========================
       📊 CARDS DASHBOARD
    ========================= */
    .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 15px;
        margin-top: 20px;
    }

    .card {
        background: #111827;
        padding: 20px;
        border-radius: 16px;
        text-align: center;
        border: 1px solid rgba(56,189,248,0.12);
        box-shadow: 0 0 20px rgba(56,189,248,0.06);
        transition: 0.2s;
    }

    .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 25px rgba(56,189,248,0.15);
    }

    .card h3 {
        font-size: 13px;
        color: #94a3b8;
        margin: 0;
    }

    .card h2 {
        margin-top: 10px;
        color: #38bdf8;
    }

    /* =========================
       📊 TABLA PAGOS
    ========================= */
    table {
        width: 100%;
        margin-top: 30px;
        border-collapse: collapse;
        background: #111827;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 0 20px rgba(56,189,248,0.08);
        border: 1px solid rgba(56,189,248,0.1);
    }

    th {
        background: #1f2937;
        color: #38bdf8;
        padding: 12px;
        font-size: 13px;
        text-transform: uppercase;
    }

    td {
        padding: 12px;
        text-align: center;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        color: #e5e7eb;
    }

    tr:hover {
        background: rgba(56,189,248,0.05);
    }

    /* =========================
       💰 ESTADOS VISUALES
    ========================= */
    .ok {
        color: #22c55e;
        font-weight: bold;
    }

    .bad {
        color: #ef4444;
        font-weight: bold;
    }

    /* =========================
       📥 BOTÓN EXCEL
    ========================= */
    .btn {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 10px;
        cursor: pointer;
        font-weight: bold;
        transition: 0.2s;
        box-shadow: 0 0 12px rgba(34,197,94,0.2);
    }

    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 0 18px rgba(34,197,94,0.35);
    }

</style>

</head>

<body>

<%- include('partials/navbar') %>

<div class="container">

<h1>💰 Reporte de Pagos</h1>

<!-- 📊 RESUMEN -->
<div class="cards">

    <div class="card">
        <h3>Total esperado</h3>
        <h2>S/ <%= total %></h2>
    </div>

    <div class="card">
        <h3>Pagado</h3>
        <h2 style="color:#22c55e;">S/ <%= pagado %></h2>
    </div>

    <div class="card">
        <h3>Pendiente</h3>
        <h2 style="color:#ef4444;">S/ <%= pendiente %></h2>
    </div>

</div>
<form method="GET" style="display:flex;gap:10px;margin-bottom:15px;">
    <select name="mes">
        <% const meses = ["Enero","Febrero","Marzo","Abril","Mayo","Junio",
        "Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre"]; %>

        <% meses.forEach((m, i) => { %>
            <option value="<%= i+1 %>" <%= mes == i+1 ? 'selected' : '' %>>
                <%= m %>
            </option>
        <% }) %>
    </select>

    <input type="number" name="anio" value="<%= anio %>">

    <button type="submit">Filtrar</button>
</form>
<!-- 📋 TABLA -->
<table>

    <tr>
        <th>Inquilino</th>
        <th>Precio</th>
        <th>Pagado</th>
        <th>Estado</th>
    </tr>

    <% detalle.forEach(i => { %>
        <tr>

            <td><%= i.nombre %></td>
            <td>S/ <%= i.precio %></td>
            <td>S/ <%= i.pago %></td>

            <td>
                <% if(i.estado === 'Pagado'){ %>
                    <span class="ok">✔ Pagado</span>
                <% } else { %>
                    <span class="bad">❌ Pendiente</span>
                <% } %>
            </td>

        </tr>
    <% }) %>

</table>

<!-- 📥 EXCEL -->
<div style="margin-top:30px;text-align:center;">
    <a href="/reportes/pagos/excel?mes=<%= mes %>&anio=<%= anio %>">
    <button class="btn" style="background:#16a34a;">
        📥 Generar Excel
    </button>
</a>
</div>

</div>

</body>
</html>