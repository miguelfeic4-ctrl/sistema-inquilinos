<!DOCTYPE html>
<html>
<head>
    <title>Pagos</title>
    <link rel="stylesheet" href="/styles.css">

<style>
body {
    background: #0f172a;
    color: white;
}

/* =========================
   📊 DASHBOARD CARDS
========================= */
.dashboard {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
    margin-top: 20px;
}

.card {
    padding: 20px;
    border-radius: 14px;
    background: #111827;
    border: 1px solid rgba(56,189,248,0.15);
    box-shadow: 0 0 20px rgba(56,189,248,0.06);
    text-align: center;
    transition: 0.2s;
}

.card:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 25px rgba(56,189,248,0.18);
}

/* =========================
   📅 FILTRO
========================= */
form select,
form input {
    background: #111827;
    color: white;
    border: 1px solid rgba(56,189,248,0.2);
    padding: 10px;
    border-radius: 10px;
    outline: none;
    margin-right: 10px;
}

form select:focus,
form input:focus {
    border-color: #38bdf8;
    box-shadow: 0 0 10px rgba(56,189,248,0.2);
}

/* =========================
   🔵 CÍRCULO PROGRESO
========================= */
.circle-container {
    display: flex;
    justify-content: center;
    margin: 30px 0;
}

.circle {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

/* =========================
   📋 TABLA PRO
========================= */
table {
    margin-top: 25px;
    width: 100%;
    border-collapse: collapse;
    background: #111827;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 0 15px rgba(0,0,0,0.3);
}

th {
    background: #1f2937;
    color: #38bdf8;
    padding: 12px;
    text-align: center;
    font-size: 13px;
}

td {
    padding: 10px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    text-align: center;
    color: #e5e7eb;
}

tr:hover {
    background: rgba(56,189,248,0.05);
}

/* =========================
   🔘 BOTÓN PAGAR
========================= */
.btn {
    padding: 7px 12px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: bold;
    transition: 0.2s;
}

.btn-pagar {
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: black;
}

.btn-pagar:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 10px rgba(34,197,94,0.4);
}

/* =========================
   ⚠ ESTADOS
========================= */
.moroso {
    background: rgba(239,68,68,0.08);
}

/* =========================
   🧠 TEXTO ESTADOS
========================= */
.estado-pagado { color: #22c55e; font-weight: bold; }
.estado-parcial { color: #facc15; font-weight: bold; }
.estado-moroso { color: #ef4444; font-weight: bold; }
.estado-pendiente { color: #fb7185; }
</style>

</head>

<body>

<%- include('partials/navbar') %>

<div class="container">

<h1>💰 Dashboard de Pagos</h1>

<!-- 🔽 FILTRO -->
<form id="filtroForm" method="GET">

    <select name="mes" id="mes">
        <% const meses = [
            "Enero","Febrero","Marzo","Abril","Mayo","Junio",
            "Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre"
        ]; %>

        <% meses.forEach((m, i) => { %>
            <option value="<%= i + 1 %>" <%= Number(mes) === (i + 1) ? 'selected' : '' %>>
                <%= m %>
            </option>
        <% }) %>
    </select>

    <input type="number" name="anio" value="<%= anio %>">

</form>

<script>
document.getElementById('mes').addEventListener('change', () => {
    document.getElementById('filtroForm').submit();
});
</script>

<!-- 🔵 PROGRESO -->
<div class="circle-container">
    <div class="circle"
        style="background: conic-gradient(#22c55e <%= total > 0 ? (pagado / total) * 360 : 0 %>deg,#1f2937 0deg);">

        <div style="
            background:#111827;
            border-radius:50%;
            width:140px;
            height:140px;
            display:flex;
            align-items:center;
            justify-content:center;
            flex-direction:column;
            border:1px solid rgba(56,189,248,0.2);
        ">
            <span style="color:#94a3b8;">Pagado</span>
            <strong style="color:#38bdf8;">S/ <%= pagado %></strong>
        </div>

    </div>
</div>

<!-- 📊 RESUMEN -->
<div class="dashboard">

    <div class="card">
        <h3>Total esperado</h3>
        <h2>S/ <%= total %></h2>
    </div>

    <div class="card">
        <h3>Pagado</h3>
        <h2 style="color:#22c55e;">S/ <%= pagado %></h2>
    </div>

    <div class="card">
        <h3>Pendiente</h3>
        <h2 style="color:#ef4444;">S/ <%= pendiente %></h2>
    </div>

</div>

<!-- 📋 TABLA -->
<h2 style="margin-top:30px;">📋 Detalle por Inquilino</h2>

<table>

<tr>
    <th>Nombre</th>
    <th>Habitación</th>
    <th>Precio</th>
    <th>Pagado</th>
    <th>Día pago</th>
    <th>Estado</th>
    <th>Acción</th>
</tr>

<% data.forEach(i => { 
    const restante = Math.max(0, i.precio - i.pago);
%>

<tr class="<%= i.estadoPago === 'moroso' ? 'moroso' : '' %>">

    <td><%= i.nombreCompleto %></td>
    <td><%= i.habitacion %></td>
    <td>S/ <%= i.precio %></td>
    <td>S/ <%= i.pago %></td>

    <td>
        <%= i.fechaIngreso ? new Date(i.fechaIngreso).getDate() : '-' %>
    </td>

    <td>
        <% if (i.estadoPago === 'pagado') { %>
            <span class="estado-pagado">✔ Pagado</span>
        <% } else if (i.estadoPago === 'parcial') { %>
            <span class="estado-parcial">⚠ Parcial</span>
        <% } else if (i.estadoPago === 'moroso') { %>
            <span class="estado-moroso">❌ Moroso</span>
        <% } else { %>
            <span class="estado-pendiente">Pendiente</span>
        <% } %>
    </td>

    <td>
        <% if (i.estadoPago !== 'pagado' && restante > 0) { %>

        <form action="/pagos/registrar" method="POST">
            <input type="hidden" name="inquilinoId" value="<%= i.id %>">
            <input type="hidden" name="mes" value="<%= mes %>">
            <input type="hidden" name="anio" value="<%= anio %>">
            <input type="hidden" name="monto" value="<%= restante %>">

            <button class="btn btn-pagar">
                Pagar S/ <%= restante %>
            </button>
        </form>

        <% } else { %>
            ✔
        <% } %>
    </td>

</tr>

<% }) %>

</table>

</div>

</body>
</html>