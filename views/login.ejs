<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <link rel="stylesheet" href="/styles.css">

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #0b1220;
            overflow: hidden;
        }

        /* GRID CYBER */
        body::before {
            content: "";
            position: absolute;
            width: 200%;
            height: 200%;
            background-image:
                linear-gradient(rgba(56,189,248,0.08) 1px, transparent 1px),
                linear-gradient(90deg, rgba(56,189,248,0.08) 1px, transparent 1px);
            background-size: 60px 60px;
            animation: moveGrid 12s linear infinite;
            z-index: 0;
            transform: rotate(15deg);
        }

        @keyframes moveGrid {
            from { transform: translate(0,0) rotate(15deg); }
            to { transform: translate(-60px,-60px) rotate(15deg); }
        }

        /* LOGIN BOX */
        .login-box {
            width: 320px;
            padding: 30px;

            border-radius: 16px;

            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(14px);

            border: 1px solid rgba(56,189,248,0.25);
            box-shadow: 0 0 25px rgba(56,189,248,0.15);

            text-align: center;

            position: relative;
            z-index: 2;

            display: flex;
            flex-direction: column;
            align-items: center;
        }

        h2 {
            color: #38bdf8;
            margin-bottom: 15px;
        }

        form {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        input {
            width: 100%;
            max-width: 260px;

            padding: 10px;
            margin: 8px 0;

            border-radius: 10px;
            border: 1px solid rgba(255,255,255,0.1);

            background: rgba(0,0,0,0.25);
            color: white;

            text-align: center;
            outline: none;
        }

        input:focus {
            border: 1px solid #38bdf8;
            box-shadow: 0 0 10px rgba(56,189,248,0.3);
        }

        button {
            width: 100%;
            max-width: 260px;

            padding: 10px;
            margin-top: 10px;

            border-radius: 10px;
            border: none;

            cursor: pointer;

            background: linear-gradient(135deg, #38bdf8, #2563eb);
            color: white;

            font-weight: bold;
            transition: 0.2s;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 15px rgba(56,189,248,0.3);
        }

        /* SHAKE ERROR */
        .shake {
            animation: shake 0.4s;
        }

        @keyframes shake {
            0% { transform: translateX(0); }
            20% { transform: translateX(-8px); }
            40% { transform: translateX(8px); }
            60% { transform: translateX(-6px); }
            80% { transform: translateX(6px); }
            100% { transform: translateX(0); }
        }

        .error {
            color: #ef4444;
            font-size: 13px;
            margin-top: 10px;
            display: none;
        }

        .login-box::after {
            content: "mikesistem1.0";
            display: block;
            margin-top: 15px;
            font-size: 11px;
            color: rgba(255,255,255,0.4);
        }
    </style>
</head>

<body>

<div class="login-box" id="loginBox">

    <h2>🔐 Acceso al Sistema</h2>

    <form method="POST" action="/login" onsubmit="return handleSubmit(event)">

        <input type="text" name="usuario" placeholder="Usuario" required>
        <input type="password" name="password" placeholder="Contraseña" required>

        <button type="submit">Ingresar</button>

        <div class="error" id="errorMsg">❌ Usuario o contraseña incorrectos</div>

    </form>

</div>

<script>
function handleSubmit(e) {
    const params = new URLSearchParams(window.location.search);

    if (params.get("error") === "1") {
        const box = document.getElementById("loginBox");
        const error = document.getElementById("errorMsg");

        box.classList.add("shake");
        error.style.display = "block";

        setTimeout(() => {
            box.classList.remove("shake");
        }, 500);

        return false;
    }

    return true;
}
</script>

</body>
</html>