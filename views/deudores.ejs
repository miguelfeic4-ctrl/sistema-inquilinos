<%- include('partials/navbar') %>

<style>
body {
    background: #0b1220;
    color: white;
    font-family: Arial;
}

.container {
    padding: 20px;
}

.card {
    background: #111827;
    padding: 15px;
    border-radius: 12px;
    margin-bottom: 15px;
}

.total {
    font-size: 28px;
    color: #fbbf24;
    font-weight: bold;
}

.mov {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px;
    border-bottom: 1px solid #1f2937;
}

input, button {
    padding: 10px;
    margin: 5px;
    border-radius: 8px;
    border: none;
}

button {
    background: #fbbf24;
    color: black;
    cursor: pointer;
}

.btn-eliminar {
    background: #ef4444;
    color: white;
    padding: 6px 10px;
    font-size: 12px;
    margin-top: 5px;
}
</style>

<div class="container">

<h2>🤝 DEUDORES / PRÉSTAMOS</h2>

<!-- 💰 TOTAL -->
<div class="card">
    <h3>Total prestado</h3>
    <div class="total">S/ <%= total || 0 %></div>
</div>

<!-- ➕ REGISTRAR PRÉSTAMO -->
<div class="card">
    <h3>Registrar préstamo</h3>

    <form method="POST" action="/deudores/agregar">

        <input type="text" name="concepto" placeholder="Nombre de persona o motivo" required>

        <input type="number" name="monto" placeholder="Monto prestado" required>

        <input type="date" name="fecha" required>

        <input type="number" name="mes" value="<%= mes %>" required>

        <input type="number" name="anio" value="<%= anio %>" required>

        <button type="submit">Registrar préstamo</button>
    </form>
</div>

<!-- 💸 PAGAR DEUDA -->
<div class="card">
    <h3>💸 Registrar pago de deuda</h3>

    <form method="POST" action="/deudores/pagar">

        <input type="text" name="concepto" placeholder="Nombre del deudor" required>

        <input type="number" name="monto" placeholder="Monto que paga" required>

        <input type="date" name="fecha" required>

        <input type="number" name="mes" value="<%= mes %>" required>

        <input type="number" name="anio" value="<%= anio %>" required>

        <button type="submit">Registrar pago</button>
    </form>
</div>

<!-- 📊 HISTORIAL -->
<div class="card">
    <h3>📊 Historial de deudores</h3>

    <% if (!prestamos || prestamos.length === 0) { %>
        <p style="color:#9ca3af;">No hay deudores activos</p>
    <% } else { %>

        <% prestamos.forEach(p => { %>

            <div class="mov">

                <div>
                    <b><%= p.concepto %></b><br>

                    <small>
                        <%= p.fecha ? new Date(p.fecha).toLocaleString() : '' %>
                    </small>
                </div>

                <div>
                    Monto: S/ <%= p.monto || 0 %><br>
                    Pagado: S/ <%= p.pagado || 0 %><br>
                    <b>Saldo: S/ <%= p.saldo || 0 %></b>

                    <!-- 🔥 BOTÓN SOLO SI YA PAGÓ TODO -->
                    <% if (p.saldo <= 0) { %>
                        <form method="POST" action="/deudores/eliminar">
                            <input type="hidden" name="concepto" value="<%= p.concepto %>">
                            <button class="btn-eliminar">Eliminar</button>
                        </form>
                    <% } %>
                </div>

            </div>

        <% }) %>

    <% } %>

</div>

</div>