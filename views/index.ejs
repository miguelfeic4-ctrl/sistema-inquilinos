<!DOCTYPE html>
<html>
<head>
    <title>Gestión de Inquilinos</title>
    <link rel="stylesheet" href="/styles.css">

    <style>
        body {
            background: #0f172a;
            font-family: Arial, sans-serif;
            color: white;
        }

        .container {
            display: flex;
            justify-content: center;
            padding-top: 40px;
        }

        /* 🔥 CARD BOTÓN */
        .open-card {
            background: linear-gradient(135deg, #1f2937, #111827);
            color: white;
            padding: 25px;
            border-radius: 16px;
            width: 260px;
            text-align: center;
            cursor: pointer;
            margin: 50px auto;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
            transition: all 0.25s ease;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .open-card:hover {
            transform: translateY(-5px) scale(1.03);
            background: linear-gradient(135deg, #2563eb, #1f2937);
        }

        /* 🔥 MODAL */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.75);
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(5px);
        }

        .modal-content {
            background: #111827;
            padding: 25px;
            border-radius: 16px;
            width: 95%;
            max-width: 520px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.6);
            position: relative;
            border: 1px solid rgba(255,255,255,0.1);

            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-content h2 {
            margin-bottom: 15px;
            text-align: center;
        }

        /* ❌ CERRAR */
        .close {
            position: absolute;
            right: 15px;
            top: 10px;
            cursor: pointer;
            font-size: 22px;
            color: #aaa;
            transition: 0.2s;
        }

        .close:hover {
            color: white;
        }

        /* 🔥 INPUTS */
        input, select, textarea {
            width: 100%;
            padding: 12px;
            margin: 8px 0;
            border: none;
            border-radius: 10px;
            background: #1f2937;
            color: white;
            outline: none;
            transition: 0.2s;
        }

        input:focus, select:focus, textarea:focus {
            background: #273449;
            border: 1px solid #3b82f6;
        }

        textarea {
            resize: none;
        }

        /* 🔘 BOTÓN */
        button {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.2s;
            margin-top: 10px;
        }

        button:hover {
            transform: translateY(-2px);
            background: linear-gradient(135deg, #1d4ed8, #1e40af);
        }

        label {
            font-size: 13px;
            color: #cbd5e1;
        }
    </style>
</head>

<body>

<%- include('partials/navbar') %>

<div class="container">

    <div class="open-card" onclick="openModal()">
        ➕ Registrar Inquilino
    </div>

</div>

<!-- MODAL -->
<div class="modal" id="modal">

    <div class="modal-content">

        <span class="close" onclick="closeModal()">✖</span>

        <h2>Registrar Inquilino</h2>

        <form action="/guardar" method="POST">

            <input type="text" name="codigo" placeholder="Código" required>
            <input type="text" name="nombreCompleto" placeholder="Nombre completo" required>
            <input type="text" name="dni" placeholder="DNI">
            <input type="text" name="telefono" placeholder="Teléfono">
            <input type="email" name="correo" placeholder="Correo">

            <select name="estado">
                <option value="activo">Activo</option>
                <option value="moroso">Moroso</option>
                <option value="retirado">Retirado</option>
                <option value="suspendido">Suspendido</option>
                <option value="en evaluacion">En evaluación</option>
            </select>

            <label>Habitación disponible</label>
            <select name="habitacion" required>
                <option value="">Selecciona habitación</option>
                <% habitaciones.forEach(h => { %>
                    <option value="<%= h.numero %>"><%= h.numero %></option>
                <% }) %>
            </select>

            <input type="date" name="fechaIngreso">
            <input type="date" name="fechaSalida">

            <select name="tieneGarantia">
                <option value="1">Tiene garantía</option>
                <option value="0">No tiene garantía</option>
            </select>

            <input type="number" name="montoGarantia" placeholder="Monto garantía">

            <textarea name="observaciones" placeholder="Observaciones"></textarea>

            <button type="submit">Guardar Inquilino</button>

        </form>

    </div>

</div>

<script>
function openModal() {
    document.getElementById('modal').style.display = 'flex';
}

function closeModal() {
    document.getElementById('modal').style.display = 'none';
}

window.onclick = function(e) {
    let modal = document.getElementById('modal');
    if (e.target === modal) {
        modal.style.display = 'none';
    }
}
</script>

</body>
</html>