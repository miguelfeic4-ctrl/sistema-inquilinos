<!DOCTYPE html>
<html>
<head>
    <title>Gestión de Inquilinos</title>
    <link rel="stylesheet" href="/styles.css">

    <style>
        body {
            background: #0b1220;
            font-family: Arial, sans-serif;
            color: white;
            margin: 0;
        }

        .container {
            display: flex;
            justify-content: center;
            align-items: center;
            padding-top: 40px;
        }

        /* 🔥 CARD BOTÓN */
        .open-card {
            background: linear-gradient(135deg, #111827, #1f2937);
            color: white;
            padding: 25px;
            border-radius: 18px;
            width: 260px;
            text-align: center;
            cursor: pointer;
            margin: 50px auto;
            box-shadow: 0 0 25px rgba(56,189,248,0.15);
            transition: 0.3s;
            border: 1px solid rgba(56,189,248,0.2);
        }

        .open-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 0 35px rgba(56,189,248,0.35);
            background: linear-gradient(135deg, #1f2937, #2563eb);
        }

        /* 🔥 MODAL */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.75);
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(6px);
        }

        .modal-content {
            background: #0b1220;
            padding: 30px;
            border-radius: 18px;
            width: 95%;
            max-width: 520px;
            box-shadow: 0 0 40px rgba(56,189,248,0.12);
            position: relative;
            border: 1px solid rgba(56,189,248,0.25);

            max-height: 90vh;
            overflow-y: auto;

            /* 🔥 CENTRADO REAL DEL FORM */
            text-align: center;
        }

        /* 🖼️ HEADER ICONO */
        .modal-content h2 {
            margin-bottom: 10px;
            color: #38bdf8;
        }

        .close {
            position: absolute;
            right: 15px;
            top: 10px;
            cursor: pointer;
            font-size: 22px;
            color: #94a3b8;
            transition: 0.2s;
        }

        .close:hover {
            color: white;
        }

        /* 🔥 INPUTS NEON */
        input, select, textarea {
            width: 100%;
            padding: 12px;
            margin: 8px 0;
            border-radius: 10px;
            background: #111827;
            color: white;
            border: 1px solid rgba(56,189,248,0.25);
            outline: none;
            transition: 0.2s;
            box-sizing: border-box;
        }

        input:focus, select:focus, textarea:focus {
            border: 1px solid #38bdf8;
            box-shadow: 0 0 12px rgba(56,189,248,0.35);
            transform: scale(1.01);
        }

        textarea {
            resize: none;
        }

        label {
            font-size: 13px;
            color: #94a3b8;
            display: block;
            text-align: left;
            margin-top: 8px;
        }

        /* 🔘 BOTÓN */
        button {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #38bdf8, #2563eb);
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
            margin-top: 12px;
            box-shadow: 0 0 15px rgba(56,189,248,0.25);
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 25px rgba(56,189,248,0.5);
        }
    </style>
</head>

<body>

<%- include('partials/navbar') %>

<div class="container">

    <div class="open-card" onclick="openModal()">
        ➕ Registrar Inquilino
    </div>

</div>

<!-- MODAL -->
<div class="modal" id="modal">

    <div class="modal-content">

        <!-- 🖼️ ICONO -->
        <div style="margin-bottom:10px;">
            <img src="https://cdn-icons-png.flaticon.com/512/1946/1946429.png"
                 width="60"
                 style="filter: drop-shadow(0 0 8px #38bdf8);" />
        </div>

        <span class="close" onclick="closeModal()">✖</span>

        <h2>Registrar Inquilino</h2>

        <form action="/guardar" method="POST">

            <input type="text" name="codigo" placeholder="Código" required>
            <input type="text" name="nombreCompleto" placeholder="Nombre completo" required>
            <input type="text" name="dni" placeholder="DNI">
            <input type="text" name="telefono" placeholder="Teléfono">
            <input type="email" name="correo" placeholder="Correo">

            <select name="estado">
                <option value="activo">Activo</option>
                <option value="moroso">Moroso</option>
                <option value="retirado">Retirado</option>
                <option value="suspendido">Suspendido</option>
                <option value="en evaluacion">En evaluación</option>
            </select>

            <label>Habitación disponible</label>
            <select name="habitacion" required>
                <option value="">Selecciona habitación</option>
                <% habitaciones.forEach(h => { %>
                    <option value="<%= h.numero %>"><%= h.numero %></option>
                <% }) %>
            </select>

            <input type="date" name="fechaIngreso">
            <input type="date" name="fechaSalida">

            <select name="tieneGarantia">
                <option value="1">Tiene garantía</option>
                <option value="0">No tiene garantía</option>
            </select>

            <input type="number" name="montoGarantia" placeholder="Monto garantía">

            <textarea name="observaciones" placeholder="Observaciones"></textarea>

            <button type="submit">Guardar Inquilino</button>

        </form>

    </div>

</div>

<script>
function openModal() {
    document.getElementById('modal').style.display = 'flex';
}

function closeModal() {
    document.getElementById('modal').style.display = 'none';
}

window.onclick = function(e) {
    let modal = document.getElementById('modal');
    if (e.target === modal) {
        modal.style.display = 'none';
    }
}
</script>

</body>
</html>